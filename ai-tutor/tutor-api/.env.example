OPENAI_MODEL=gpt-4.1-mini

# ── Phase 1: Conversational AI (ConversationEngine) ──────────────────────────
# Primary: Anthropic Claude (recommended — more natural tutoring)
ANTHROPIC_API_KEY=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
# Model for tutoring chat (claude-sonnet-4-6 = best balance of quality/speed/cost)
AI_TUTOR_CHAT_MODEL=claude-sonnet-4-6
# Max conversation turns kept in memory per session (each turn = 1 user + 1 assistant)
AI_TUTOR_CHAT_HISTORY_TURNS=6
# Max tokens for each LLM reply (300 ≈ 3-4 clear sentences)
AI_TUTOR_CHAT_MAX_TOKENS=300
# Seconds before LLM call times out
AI_TUTOR_CHAT_TIMEOUT_SEC=15
AI_TUTOR_ADAPTIVE_POLICY_ENABLED=true
AI_TUTOR_ADAPTIVE_POLICY_PATH=/opt/robodynamics/vedic_math/policies/adaptive_policy_v1.json
AI_TUTOR_ADAPTIVE_POLICY_MIN_OBS=5
AI_TUTOR_TEMPLATE_API_URL=http://localhost:8080/robodynamics/api/ai-tutor/course-template
AI_TUTOR_TEMPLATE_TIMEOUT_SEC=8
AI_TUTOR_TEMPLATE_CACHE_TTL_SEC=120
AI_TUTOR_DYNAMIC_COURSE_TEMPLATE_ENABLED=true
AI_TUTOR_TEMPLATE_COURSE_IDS=neet_physics:155,neet_chemistry:156,neet_biology:157
